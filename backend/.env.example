# Mysore Civic REST API Backend
# Flask application configuration

# Enable debug mode for local development
FLASK_DEBUG=1
FLASK_APP=app.py

# Your local or Atlas MongoDB URI
MONGO_URI=mongodb://localhost:27017/mysore_civic

# JWT Secret Key (replace with secure key in production)
JWT_SECRET_KEY=dev-secret-key-change-in-production

# Allow CORS from this origin
CORS_ORIGINS=http://localhost:5173
